---
// Nav — site header that overlays the hero.
// Logo on the left, nav links on the right (hidden on mobile, replaced by a
// hamburger button placeholder). All colors/fonts come from tokens.css.
//
// `wrapped` makes the nav blend into the grey hero card below it (transparent
// bar + grey rounded-top inner) so the two read as one card. Off by default, so
// most pages keep the plain white nav.

interface Props {
  wrapped?: boolean;
}

const { wrapped = false } = Astro.props;

const links = [
  { label: "WORK", href: "/work" },
  { label: "LAB", href: "/lab" },
  { label: "ABOUT", href: "/about" },
];
---

<header class:list={["nav", { "nav--wrapped": wrapped }]}>
  <nav class="nav__inner">
    <a href="/" class="nav__logo">ALICE LI</a>

    <ul class="nav__links">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="nav__link">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button class="nav__menu" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    /* Opaque white so page content scrolls cleanly underneath */
    background: var(--surface-primary);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 24px;
  }

  /* Wrapped: blend the nav into the grey hero card below. The full-width white
     bar goes transparent; the centered inner becomes the top of the grey card
     (rounded top corners), with its content inset to line up with the hero
     below. The hero supplies the matching rounded bottom corners. */
  .nav--wrapped {
    background: transparent;
  }

  .nav--wrapped .nav__inner {
    background: var(--surface-secondary);
    border-radius: 40px 40px 0 0;
    padding: 40px 60px 24px;
  }

  @media (max-width: 899px) {
    .nav--wrapped .nav__inner {
      padding: 32px 24px 24px;
    }
  }

  .nav__logo {
    font-family: var(--font-geist);
    font-weight: 800;
    font-size: 24px;
    letter-spacing: 4.8px;
    color: var(--text-primary);
    text-decoration: none;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 40px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-family: var(--font-figtree);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--text-primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .nav__link:hover {
    opacity: 0.7;
  }

  /* Hamburger button — hidden on desktop, shown on mobile */
  .nav__menu {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .nav__menu span {
    display: block;
    height: 2px;
    width: 24px;
    background: var(--text-primary);
    border-radius: 2px;
  }

  @media (max-width: 767px) {
    .nav__links {
      display: none;
    }

    .nav__menu {
      display: flex;
    }
  }
</style>
